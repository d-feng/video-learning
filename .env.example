# Copy to .env and fill in your values

# Required
OPENAI_API_KEY=sk-...

# Vision provider: "openai" (default) or "gemini"
VISION_PROVIDER=openai

# Gemini (required only when VISION_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional tuning
OPENAI_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
VISION_BATCH_SIZE=1         # frames per GPT-4o call (ignored for Gemini)

FRAME_INTERVAL=2.0          # seconds between extracted frames
TRANSCRIPT_WINDOW_SEC=4.0   # transcript context window per frame
STORAGE_DIR=./storage        # where frames, audio, DB are stored
